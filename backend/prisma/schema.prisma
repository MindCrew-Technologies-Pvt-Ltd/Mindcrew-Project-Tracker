datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum HealthStatus {
  ON_TRACK
  AT_RISK
  DELAYED
}

enum DocumentCategory {
  PROPOSAL
  SRS
  DESIGN
  LOGO
  MEETING_NOTES
  CONTRACT
  DELIVERY_FILES
  SCREENSHOTS
  VIDEO
  OTHER
  // Legacy values kept for existing rows (enum removal would be destructive):
  TECHNICAL
  REPORT
}

enum NotificationType {
  EDIT_REQUEST_UPDATE
  PROJECT_UPDATE
  WEEKLY_UPDATE_REMINDER
  TIMESHEET
  SYSTEM
}

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum EditRequestStatus {
  PENDING
  APPROVED
  REJECTED
  REVOKED
}

model User {
  id                  String    @id @default(cuid())
  name                String
  email               String    @unique
  passwordHash        String
  phone               String?
  department          String?
  designation         String?
  role                Role      @default(EMPLOYEE)
  isActive            Boolean   @default(true)
  fcmToken            String?
  lastLoginAt         DateTime?
  passwordResetToken  String?
  passwordResetExpiry DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  ownedProjects    Project[]       @relation("owner")
  projectMembers   ProjectMember[]
  weeklyUpdates    WeeklyUpdate[]
  documents        Document[]
  notifications    Notification[]
  editRequests     EditRequest[]   @relation("requester")
  reviewedRequests EditRequest[]   @relation("reviewer")
  activityLogs     ActivityLog[]
  timeEntries      TimeEntry[]
  timesheetWeeks   TimesheetWeek[] @relation("tsWeekUser")
  reviewedWeeks    TimesheetWeek[] @relation("tsWeekReviewer")
  activeTimer      ActiveTimer?
  billableRate     BillableRate?
  apiTokens        ApiToken[]
}

model Project {
  id             String        @id @default(cuid())
  name           String
  clientName     String?
  clientLocation String?
  clientWhatsapp String?
  clientGmail    String?
  description    String?
  status         ProjectStatus @default(DRAFT)
  priority       Priority      @default(MEDIUM)
  technologies   String[]
  tags           String[]
  repositoryUrls String[]
  liveUrls       String[]
  videoUrls      String[]
  startDate      DateTime?
  endDate        DateTime?
  deadline       DateTime?
  budget         Float?
  ownerId        String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  owner         User            @relation("owner", fields: [ownerId], references: [id])
  teamMembers   ProjectMember[]
  weeklyUpdates WeeklyUpdate[]
  documents     Document[]
  editRequests  EditRequest[]
  notifications Notification[]
  timeEntries   TimeEntry[]
  activeTimers  ActiveTimer[]
}

// ==== Timesheet module (docs/timesheet/04-database-design.md) ====

model TimeEntry {
  id          String   @id @default(cuid())
  userId      String
  projectId   String
  date        DateTime
  minutes     Int
  description String?
  billable    Boolean  @default(true)
  isoYear     Int
  isoWeek     Int
  source      String   @default("MANUAL")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId, isoYear, isoWeek])
  @@index([projectId, date])
  @@index([date])
}

model TimesheetWeek {
  id           String          @id @default(cuid())
  userId       String
  isoYear      Int
  isoWeek      Int
  status       TimesheetStatus @default(SUBMITTED)
  totalMinutes Int
  submittedAt  DateTime        @default(now())
  reviewedById String?
  reviewedAt   DateTime?
  reviewNote   String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  user       User  @relation("tsWeekUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("tsWeekReviewer", fields: [reviewedById], references: [id])

  @@unique([userId, isoYear, isoWeek])
  @@index([status])
}

model ActiveTimer {
  id             String   @id @default(cuid())
  userId         String   @unique
  projectId      String
  description    String?
  billable       Boolean  @default(true)
  startedAt      DateTime @default(now())
  accumulatedMin Int      @default(0)
  isPaused       Boolean  @default(false)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model BillableRate {
  id         String   @id @default(cuid())
  userId     String   @unique
  hourlyRate Float
  currency   String   @default("INR")
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Holiday {
  id   String   @id @default(cuid())
  date DateTime @unique
  name String
}

model TimesheetSettings {
  id                 String  @id @default("singleton")
  weeklyTargetHours  Int     @default(40)
  reminderEnabled    Boolean @default(false)
  reminderDay        Int     @default(1)
  reminderHour       Int     @default(10)
  timezone           String  @default("Asia/Kolkata")
  // AI-only mode (default): time is logged exclusively by connected AI
  // assistants; manual add/edit/delete, the timer and manual submission are
  // blocked for non-admins so hours/descriptions can't be doctored.
  manualEntryEnabled Boolean @default(false)
  // Anti-overcount cap: today's logged total may not exceed the time elapsed
  // since this hour (org timezone). 8 = 08:00. Midnight-based capping let a
  // "full 8h day" through at 2 PM because 14h had already elapsed.
  workdayStartHour   Int     @default(8)
}

model ApiToken {
  id         String    @id @default(cuid())
  userId     String
  name       String
  tokenHash  String    @unique
  prefix     String
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      String   @default("MEMBER")
  joinedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model WeeklyUpdate {
  id                   String       @id @default(cuid())
  projectId            String
  authorId             String
  weekNumber           Int
  year                 Int
  progressSummary      String
  completedTasks       String[]
  plannedTasks         String[]
  blockers             String?
  milestones           String?
  healthStatus         HealthStatus @default(ON_TRACK)
  completionPercentage Int          @default(0)
  hoursLogged          Float?
  attachments          String[]
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id])

  @@unique([projectId, weekNumber, year])
}

model Document {
  id           String           @id @default(cuid())
  projectId    String
  uploadedById String
  fileName     String
  fileUrl      String
  fileType     String
  fileSize     Int?
  category     DocumentCategory @default(OTHER)
  description  String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation(fields: [uploadedById], references: [id])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(SYSTEM)
  isRead    Boolean          @default(false)
  projectId String?
  relatedId String?
  createdAt DateTime         @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

model EditRequest {
  id            String            @id @default(cuid())
  projectId     String
  requestedById String
  reason        String
  // duration/expiresAt are legacy: approved access no longer expires (user
  // decision 2026-07-15). Kept nullable so the auto db push stays non-destructive.
  duration      String?
  comments      String?
  status        EditRequestStatus @default(PENDING)
  reviewedById  String?
  reviewerNotes String?
  expiresAt     DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requestedBy User    @relation("requester", fields: [requestedById], references: [id])
  reviewedBy  User?   @relation("reviewer", fields: [reviewedById], references: [id])
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  module      String
  description String
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}
